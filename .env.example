NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://your-addon.example.com

# Keep this secret stable. Existing Stremio install URLs stop decrypting if it changes.
# Generate with: openssl rand -base64 48
ENCRYPTION_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Optional. Set this to run the bundled cloudflared service with:
# docker compose --profile cloudflare up -d --build
CLOUDFLARED_TOKEN=

# Optional cache tuning.
CACHE_TTL_SECONDS=300
SETUP_SESSION_TTL_SECONDS=600
